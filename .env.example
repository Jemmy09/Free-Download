# Copy this file, fill in your real values in Render's Environment Variables dashboard.
# NEVER commit real credentials to GitHub.

# Aiven MySQL connection
DB_HOST=your-aiven-mysql-host.aivencloud.com
DB_PORT=3306
DB_USER=avnadmin
DB_PASS=your_password_here
DB_NAME=defaultdb
DB_SSL=true

# JWT — generate a long random string, e.g: openssl rand -hex 64
JWT_SECRET=replace_with_a_very_long_random_secret_string

# Your GitHub Pages frontend URL (no trailing slash)
FRONTEND_URL=https://jemmy09.github.io
